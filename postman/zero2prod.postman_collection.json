{
  "info": {
    "name": "zero2prod",
    "_postman_id": "zero2prod-collection",
    "description": "API collection for the zero2prod newsletter service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health_check",
          "host": ["{{base_url}}"],
          "path": ["health_check"]
        },
        "description": "Returns 200 OK if the server is running."
      },
      "response": []
    },
    {
      "name": "Subscribe",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "email",
              "value": "user@example.com",
              "type": "text"
            },
            {
              "key": "name",
              "value": "John Doe",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/subscriptions",
          "host": ["{{base_url}}"],
          "path": ["subscriptions"]
        },
        "description": "Subscribe a new user to the newsletter. Requires 'email' and 'name' as form fields."
      },
      "response": []
    }
  ]
}
